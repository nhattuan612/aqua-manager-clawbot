# Core app settings
# Keep app name and port here so the same package can run as staging/live on
# different VPS hosts without touching source code.
AQUA_APP_NAME=aqua_manager_clawbot
AQUA_HOST=0.0.0.0
AQUA_PORT=6080
AQUA_ADMIN_PASSWORD=123456789
AQUA_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
AQUA_PUBLIC_BASE_URL=http://your-domain-or-ip:6080

# OpenClaw / workspace paths
# These values are the only host-specific pieces that usually need changing
# when moving AQUA Manager to another VPS or another OpenClaw home.
AQUA_OPENCLAW_HOME=/home/your-user/.openclaw
AQUA_WORKSPACE_DIR=/home/your-user/.openclaw/workspace
AQUA_TOOLS_DIR=/home/your-user/.openclaw/workspace/tools
AQUA_DATA_DIR=/home/your-user/.openclaw/workspace/data
AQUA_SKILLS_DIR=/home/your-user/.openclaw/workspace/skills
AQUA_BACKUP_DIR=/home/your-user/.openclaw/workspace/backups
AQUA_AUTH_PROFILES=/home/your-user/.openclaw/agents/main/agent/auth-profiles.json

# Binaries / runtime
AQUA_OPENCLAW_BIN=openclaw
AQUA_PM2_BIN=pm2
AQUA_GATEWAY_URL=http://127.0.0.1:18789

# SSH details used only for the OpenClaw helper text inside AQUA Dashboard.
# They do not change OpenClaw itself; they only show operators the right tunnel
# command for their own VPS.
AQUA_SSH_HOST=your-vps-host
AQUA_SSH_PORT=22
AQUA_SSH_USER=your-user
AQUA_GATEWAY_TUNNEL_LOCAL_PORT=18789
