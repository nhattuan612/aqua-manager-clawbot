# Core app settings
# Keep app name and port here so the same package can run as staging/live on
# different VPS hosts without touching source code.
AQUA_APP_NAME=aqua_manager_clawbot
AQUA_HOST=0.0.0.0
AQUA_PORT=6080
AQUA_ADMIN_PASSWORD=CHANGE_ME
AQUA_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET

# OpenClaw / workspace paths
# These values are the only host-specific pieces that usually need changing
# when moving AQUA Manager to another VPS or another OpenClaw home.
AQUA_OPENCLAW_HOME=/home/ubuntu/.openclaw
AQUA_WORKSPACE_DIR=/home/ubuntu/.openclaw/workspace
AQUA_TOOLS_DIR=/home/ubuntu/.openclaw/workspace/tools
AQUA_DATA_DIR=/home/ubuntu/.openclaw/workspace/data
AQUA_SKILLS_DIR=/home/ubuntu/.openclaw/workspace/skills
AQUA_BACKUP_DIR=/home/ubuntu/.openclaw/workspace/backups
AQUA_AUTH_PROFILES=/home/ubuntu/.openclaw/agents/main/agent/auth-profiles.json

# Binaries / runtime
AQUA_OPENCLAW_BIN=/home/ubuntu/.npm-global/bin/openclaw
AQUA_PM2_BIN=/home/ubuntu/.npm-global/bin/pm2
AQUA_GATEWAY_URL=http://127.0.0.1:18789
