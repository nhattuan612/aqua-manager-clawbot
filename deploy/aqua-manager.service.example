[Unit]
Description=AQUA Manager ClawBot
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/.aqua-manager-clawbot
Environment=AQUA_ENV_FILE=%h/.aqua-manager-clawbot/.env
ExecStart=%h/.aqua-manager-clawbot/deploy/run-dashboard.sh
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
